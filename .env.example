# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgres://skintrader:skintrader_secret@localhost:5432/skintrader?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=5

# DragonflyDB (Redis-compatible)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Apple Sign-In
APPLE_TEAM_ID=your-apple-team-id
APPLE_BUNDLE_ID=your-apple-bundle-id
APPLE_KEY_ID=your-apple-key-id
APPLE_KEY_PATH=path/to/AuthKey.p8

# File Upload
MAX_FILE_SIZE=5242880
MAX_FILES=5
UPLOAD_DIR=uploads
KYC_MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Cache TTL (seconds)
CACHE_POSTS_TTL=300
CACHE_GAMES_TTL=3600
CACHE_USER_TTL=600

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3004,http://localhost:5173

# Subscription
SUBSCRIPTION_PRICE_UZS=10000
SUBSCRIPTION_PRICE_USD=1
SUBSCRIPTION_DURATION_DAYS=30
GRACE_PERIOD_DAYS=3

# PayMe
PAYME_MERCHANT_ID=your_merchant_id
PAYME_SECRET_KEY=your_secret_key
PAYME_CALLBACK_URL=http://localhost:3000/api/v1/payments/payme/callback
PAYME_WEBHOOK_URL=http://localhost:3000/api/v1/payments/payme/webhook
PAYME_TEST_MODE=true

# Click
CLICK_MERCHANT_ID=your_merchant_id
CLICK_SERVICE_ID=your_service_id
CLICK_SECRET_KEY=your_secret_key
CLICK_MERCHANT_USER=your_merchant_user
CLICK_WEBHOOK_URL=http://localhost:3000/api/v1/payments/click

# Xazna
XAZNA_BASE_URL=https://api.xazna.uz
XAZNA_API_KEY=your_api_key
XAZNA_SECRET_KEY=your_secret_key
XAZNA_WEBHOOK_URL=http://localhost:3000/api/v1/payments/xazna/webhook

# Uzum Bank
UZUM_BASE_URL=https://api.uzumbank.uz
UZUM_TERMINAL_ID=your_terminal_id
UZUM_SECRET_KEY=your_secret_key
UZUM_WEBHOOK_URL=http://localhost:3000/api/v1/payments/uzum/webhook

# KYC
KYC_FACE_MATCH_THRESHOLD=0.6

# Face Matching Service (gRPC)
FACE_SERVICE_ADDRESS=localhost:50051
FACE_SERVICE_TIMEOUT_SECS=30

# Admin (initial superadmin)
ADMIN_EMAIL=admin@skintrader.uz
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Super Admin
